#!/usr/bin/env bash
# Auto-sync the Hugging Face Space whenever this repo's `main` is pushed. Best-effort: a
# failure here must NOT block the push to origin, so we always exit 0. Only fires for pushes
# that include refs/heads/main, so feature-branch pushes don't deploy work-in-progress.
ROOT="$(git rev-parse --show-toplevel)"

deploy=0
while read -r _localref _localsha remoteref _remotesha; do
  case "$remoteref" in
    refs/heads/main) deploy=1 ;;
  esac
done

[ "$deploy" = 1 ] || exit 0

bash "$ROOT/scripts/deploy-hf.sh" \
  || echo "[pre-push] HF deploy skipped/failed — push to origin continues." >&2
exit 0
