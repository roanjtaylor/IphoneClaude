# Copy to `.env` for local dev, or set these as env vars on the cloud host.

# --- Subscription auth -------------------------------------------------------
# Locally: leave UNSET if you've already run `claude login` (the SDK reads
#   ~/.claude/.credentials.json automatically).
# On a headless cloud host: run `claude setup-token` locally once, paste the token here.
CLAUDE_CODE_OAUTH_TOKEN=

# --- App auth ----------------------------------------------------------------
# The secret the app must send as the `x-app-secret` header. Leave EMPTY locally to
# keep the gate open for curl testing. ALWAYS set a long random value on the public host.
APP_SHARED_SECRET=

# --- Optional ----------------------------------------------------------------
# CLAUDE_MODEL=claude-opus-4-8
# PORT=5174

# --- DO NOT SET --------------------------------------------------------------
# Setting ANTHROPIC_API_KEY switches Claude to PAID per-token API billing instead of
# your subscription. Leave it unset.
# ANTHROPIC_API_KEY=
